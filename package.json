{
  "name": "attest",
  "version": "0.1.0",
  "description": "Stateless web capture engine: ad-blocked full-page screenshot + reader-mode Markdown + signed offline-verifiable receipt.",
  "author": "PrabakaranR-code",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrabakaranR-code/Attest.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "tsx src/cli/verify.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.2",
    "@types/turndown": "^5.0.6",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@ghostery/adblocker-playwright": "^2.18.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "fastify": "^5.10.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "turndown": "^7.2.4",
    "zod": "^4.4.3"
  }
}
